{
  "manifest_version": 3,
  "name": "CopyPaste Orchestrator",
  "version": "1.0.0",
  "description": "WebSocket-driven Chrome automation puppet for ChatGPT and Claude.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://*.chatgpt.com/*",
    "https://chatgpt.com/*",
    "https://*.claude.ai/*",
    "https://claude.ai/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src ws://localhost:8080 http://localhost:8080;"
  },
  "background": {
    "service_worker": "background.js"
  }
}
