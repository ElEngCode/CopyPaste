{
  "manifest_version": 3,
  "name": "CopyPaste",
  "version": "1.0.0",
  "description": "Manual step-by-step workflow automation between ChatGPT and Claude.",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "downloads"
  ],
  "host_permissions": [
    "https://*.chatgpt.com/*",
    "https://chatgpt.com/*",
    "https://*.claude.ai/*",
    "https://claude.ai/*"
  ],
  "action": {
    "default_title": "CopyPaste",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
